# Copy this file to .env and fill in your real values.
# NEVER commit .env — only .env.example belongs in git.

# =============================================================================
# Plaid
# =============================================================================
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=development                  # sandbox | development | production
PLAID_WEBHOOK_URL=https://your-railway-url.railway.app/webhook

# =============================================================================
# Claude (Anthropic)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# Supabase
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   # never the anon key

# =============================================================================
# Notion
# =============================================================================
NOTION_TOKEN=secret_...
NOTION_ROOT_PAGE_ID=your_autobudget_root_page_id

# =============================================================================
# Gmail (OAuth2 via nodemailer — uses HTTPS, works on Railway)
# =============================================================================
GMAIL_USER=ro.rakhit@gmail.com
GMAIL_CLIENT_ID=your_oauth2_client_id             # Google Cloud Console → Credentials → OAuth 2.0 Client ID (Desktop app)
GMAIL_CLIENT_SECRET=your_oauth2_client_secret
GMAIL_REFRESH_TOKEN=your_oauth2_refresh_token     # obtained via OAuth2 consent flow with gmail.send scope

# =============================================================================
# App
# =============================================================================
SETUP_SECRET=your_random_secret_for_link_and_setup_pages   # generate with: openssl rand -hex 32
PORT=3000
